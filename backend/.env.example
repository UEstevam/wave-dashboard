# Copie este arquivo para .env e preencha os valores

# MongoDB Atlas connection string
# Formato: mongodb+srv://user:password@cluster.mongodb.net/wave_dashboard
MONGODB_URI=

# URL do frontend (Vercel) - usado para configurar CORS
FRONTEND_URL=https://seu-app.vercel.app

# OAuth redirect URIs (substitua pela URL do Render)
DRIVE_REDIRECT_URI=https://wave-dashboard-api.onrender.com/api/drive/callback
YOUTUBE_REDIRECT_URI=https://wave-dashboard-api.onrender.com/api/youtube/callback

# Porta (Render define automaticamente)
PORT=3001
